<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_ai_agent_form" model="ir.ui.view">
        <field name="name">ai.agent.form</field>
        <field name="model">ai.agent</field>
        <field name="arch" type="xml">
            <form string="AI Agent">
                <sheet>
                    <widget name="web_ribbon" title="Archived" bg_color="bg-danger" invisible="active == True"/>
                    <field name="active" invisible="1"/>
                    <div class="oe_title">
                        <h1><field name="name" placeholder="e.g., Aisha Support Agent"/></h1>
                    </div>
                    <group>
                        <group string="API Settings">
                            <field name="provider"/>
                            <field name="api_key" widget="password"/>
                            <field name="model_name"/>
                            <field name="endpoint_url"/>
                        </group>
                        <group string="Odoo Integration">
                            <field name="user_id"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="System Prompt (The Brain)">
                            <field name="system_prompt" placeholder="You are an expert Odoo consultant..."/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_ai_agent_tree" model="ir.ui.view">
        <field name="name">ai.agent.tree</field>
        <field name="model">ai.agent</field>
        <field name="arch" type="xml">
            <list string="AI Agents">
                <field name="name"/>
                <field name="provider"/>
                <field name="model_name"/>
                <field name="user_id"/>
            </list>
        </field>
    </record>

    <record id="action_ai_agent" model="ir.actions.act_window">
        <field name="name">AI Agents</field>
        <field name="res_model">ai.agent</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="menu_ai_agent_root"
              name="AI Agents"
              parent="base.menu_custom"
              action="action_ai_agent"
              sequence="10"/>
</odoo>
