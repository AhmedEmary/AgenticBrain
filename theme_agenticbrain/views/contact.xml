<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="theme_agenticbrain_contactus" inherit_id="website.contactus" name="Agentic Brain Contact">
        <xpath expr="//div[@id='wrap']" position="replace">
            <div id="wrap" class="oe_structure oe_empty">

                <section class="s_banner pt96 pb96 text-center" style="background-color: #0A192F;">
                    <div class="container mt-5 mb-5">
                        <p class="fw-bold mb-3" style="color: #00D2B5; letter-spacing: 2px; text-transform: uppercase;">Get in touch</p>
                        <h1 class="display-3 fw-bold mb-4 text-white">Let's build something great together</h1>
                        <p class="lead fs-4" style="color: #94A3B8; max-width: 800px; margin: 0 auto;">Schedule a consultation to discuss how intelligent automation can transform your business operations.</p>
                    </div>
                </section>

                <section class="s_contact pt96 pb96 text-start" style="background-color: #F8FAFC;">
                    <div class="container">
                        <div class="row gx-5">

                            <div class="col-lg-6 mb-5 mb-lg-0">
                                <div class="agentic-card">
                                    <h2 class="h3 fw-bold mb-4" style="color: #0A192F;">Send us a message</h2>

                                    <form action="/website/form/" method="post" data-model_name="crm.lead" class="s_website_form" enctype="multipart/form-data">
                                        <div class="row">
                                            <div class="col-md-6 mb-4">
                                                <label class="fw-bold mb-2 text-dark">Name</label>
                                                <input type="text" name="contact_name" class="agentic-form-control s_website_form_input" placeholder="Maya Chen" required="1"/>
                                            </div>
                                            <div class="col-md-6 mb-4">
                                                <label class="fw-bold mb-2 text-dark">Email</label>
                                                <input type="email" name="email_from" class="agentic-form-control s_website_form_input" placeholder="maya@company.com" required="1"/>
                                            </div>
                                        </div>
                                        <div class="mb-4">
                                            <label class="fw-bold mb-2 text-dark">Company</label>
                                            <input type="text" name="partner_name" class="agentic-form-control s_website_form_input" placeholder="Meridian Labs"/>
                                        </div>
                                        <div class="mb-4">
                                            <label class="fw-bold mb-2 text-dark">Message</label>
                                            <textarea name="description" class="agentic-form-control s_website_form_input" rows="5" placeholder="Tell us about your project and how we can help..." required="1"></textarea>
                                        </div>
                                        <button type="submit" class="btn btn-primary btn-lg w-100 mt-2">Schedule a consultation</button>
                                    </form>
                                </div>
                            </div>

                            <div class="col-lg-6 ps-lg-5">
                                <h2 class="h3 fw-bold mb-4" style="color: #0A192F;">Contact information</h2>
                                <p class="text-muted fs-5 mb-5">Have questions about our services? Want to discuss a specific project? We're here to help. Reach out through any of the channels below.</p>

                                <div class="d-flex align-items-center mb-4">
                                    <div class="icon-wrapper me-4" style="background: rgba(0, 210, 181, 0.1); width: 64px; height: 64px; border-radius: 12px; display: flex; align-items: center; justify-content: center; color: #00D2B5;">
                                        <i class="fa fa-2x fa-envelope"></i>
                                    </div>
                                    <div>
                                        <div class="fw-bold text-dark">Email</div>
                                        <a href="mailto:contact@agenticbrain.tech" class="text-muted text-decoration-none">contact@agenticbrain.tech</a>
                                    </div>
                                </div>

                                <div class="d-flex align-items-center mb-4">
                                    <div class="icon-wrapper me-4" style="background: rgba(0, 210, 181, 0.1); width: 64px; height: 64px; border-radius: 12px; display: flex; align-items: center; justify-content: center; color: #00D2B5;">
                                        <i class="fa fa-2x fa-phone"></i>
                                    </div>
                                    <div>
                                        <div class="fw-bold text-dark">Phone</div>
                                        <a href="tel:+15551234567" class="text-muted text-decoration-none">+1 (555) 123-4567</a>
                                    </div>
                                </div>

                                <div class="d-flex align-items-center mb-5">
                                    <div class="icon-wrapper me-4" style="background: rgba(0, 210, 181, 0.1); width: 64px; height: 64px; border-radius: 12px; display: flex; align-items: center; justify-content: center; color: #00D2B5;">
                                        <i class="fa fa-2x fa-clock-o"></i>
                                    </div>
                                    <div>
                                        <div class="fw-bold text-dark">Business hours</div>
                                        <div class="text-muted">Mon-Fri, 9:00 AM - 6:00 PM PST</div>
                                    </div>
                                </div>

                                <div class="pt-4" style="border-top: 1px solid #e5e7eb;">
                                    <h3 class="h5 fw-bold mb-3" style="color: #0A192F;">What to expect</h3>
                                    <ul class="list-unstyled text-muted">
                                        <li class="mb-2"><i class="fa fa-circle me-2" style="color: #00D2B5; font-size: 8px;"></i> We'll respond within 24 hours on business days</li>
                                        <li class="mb-2"><i class="fa fa-circle me-2" style="color: #00D2B5; font-size: 8px;"></i> Initial consultation calls typically last 30-45 minutes</li>
                                        <li><i class="fa fa-circle me-2" style="color: #00D2B5; font-size: 8px;"></i> We'll provide a detailed proposal within 3-5 business days</li>
                                    </ul>
                                </div>
                            </div>

                        </div>
                    </div>
                </section>

            </div>
        </xpath>
    </template>
</odoo>
