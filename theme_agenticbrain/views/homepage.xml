<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="theme_agenticbrain_homepage" inherit_id="website.homepage" name="Agentic Brain Homepage">
        <xpath expr="//div[@id='wrap']" position="replace">
            <div id="wrap" class="oe_structure oe_empty">

                <section class="s_banner pt96 pb96" data-snippet="s_banner" style="background-color: #0A192F;">
                    <div class="container align-items-center d-flex mt-5 mb-5">
                        <div class="row">
                            <div class="col-lg-8">
                                <h1 class="display-3 fw-bold mb-4" style="color: #00FFCC;">Stop Running Your Business.<br/>Let Your Business Run Itself.</h1>
                                <p class="lead mb-4 fs-3" style="color: #CCD6F6;">We combine the power of Odoo with custom Artificial Intelligence to automate workflows, integrate systems, and scale growth.</p>
                                <a href="/contactus" class="btn btn-primary btn-lg me-3 mb-2" style="color: #0A192F; font-weight: bold;">Book a Free AI Audit</a>
                            </div>
                        </div>
                    </div>
                </section>

                <section class="s_features pt80 pb80" data-snippet="s_features" style="background-color: #112240;">
                    <div class="container">
                        <div class="row text-center mb-5">
                            <h2 class="display-4 fw-bold" style="color: #ffffff;">Our Core Solutions</h2>
                        </div>
                        <div class="row">
                            <div class="col-lg-4 pt24 pb24 text-center">
                                <i class="fa fa-4x fa-cogs mb-3" style="color: #00FFCC;"></i>
                                <h3 class="h4 fw-bold" style="color: #ffffff;">Odoo Implementation</h3>
                                <p style="color: #CCD6F6;">Expert configuration mapping directly to your exact business logic.</p>
                            </div>
                            <div class="col-lg-4 pt24 pb24 text-center">
                                <i class="fa fa-4x fa-robot mb-3" style="color: #00FFCC;"></i>
                                <h3 class="h4 fw-bold" style="color: #ffffff;">Custom AI Agents</h3>
                                <p style="color: #CCD6F6;">Your new digital employees, built right into your ERP system.</p>
                            </div>
                            <div class="col-lg-4 pt24 pb24 text-center">
                                <i class="fa fa-4x fa-plug mb-3" style="color: #00FFCC;"></i>
                                <h3 class="h4 fw-bold" style="color: #ffffff;">System Integrations</h3>
                                <p style="color: #CCD6F6;">Connecting Odoo to your entire existing software stack flawlessly.</p>
                            </div>
                        </div>
                    </div>
                </section>

            </div>
        </xpath>
    </template>
</odoo>
