<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="theme_agenticbrain_aboutus" inherit_id="website.aboutus" name="Agentic Brain About Us">
        <xpath expr="//div[@id='wrap']" position="replace">
            <div id="wrap" class="oe_structure oe_empty">

                <section class="s_banner pt120 pb120 text-center" style="background-color: #0A192F;">
                    <div class="container mt-5 mb-5">
                        <p class="fw-bold mb-3" style="color: #00D2B5; letter-spacing: 2px; text-transform: uppercase;">About Us</p>
                        <h1 class="display-3 fw-bold mb-4 text-white">Building the future of work</h1>
                        <p class="lead fs-4" style="color: #94A3B8; max-width: 800px; margin: 0 auto;">We create digital employees that transform how businesses operate, giving teams the freedom to focus on what matters most.</p>
                    </div>
                </section>

                <section class="s_text_image pt96 pb96 bg-white text-start">
                    <div class="container">
                        <div class="row align-items-center">
                            <div class="col-lg-12 pe-lg-5 mb-5 mb-lg-0 text-center text-lg-start">
                                <p class="fw-bold mb-3" style="color: #00D2B5; letter-spacing: 1px; text-transform: uppercase;">Our Philosophy</p>
                                <h2 class="display-5 fw-bold mb-4" style="color: #0A192F;">The Agentic Brain concept</h2>
                                <div style="width: 80px; height: 4px; background-color: #00D2B5; margin-bottom: 2rem;"></div>
                                <p class="text-muted fs-5 mb-4"><strong style="color: #0A192F;">The Brain</strong> represents intelligence - the ability to understand complex business processes, learn from patterns, and make informed decisions.</p>
                                <p class="text-muted fs-5 mb-4"><strong style="color: #0A192F;">Agentic</strong> represents action - systems that don't just analyze, but actively execute tasks, solve problems, and drive outcomes.</p>
                                <p class="text-muted fs-5">Together, they form the foundation of our approach: building intelligent systems that think and act autonomously, becoming true digital employees within your organization.</p>
                            </div>
                        </div>
                    </div>
                </section>

                <section class="s_timeline pt96 pb96" style="background-color: #F8FAFC;">
                    <div class="container text-start" style="max-width: 800px; margin: 0 auto;">
                        <div class="text-center mb-5">
                            <p class="fw-bold mb-3" style="color: #00D2B5; letter-spacing: 1px; text-transform: uppercase;">Our Journey</p>
                            <h2 class="display-5 fw-bold mb-4" style="color: #0A192F;">Company evolution</h2>
                        </div>

                        <div class="d-flex mb-5">
                            <div class="timeline-badge me-4">2019</div>
                            <div>
                                <h3 class="h4 fw-bold" style="color: #0A192F;">Foundation</h3>
                                <p class="text-muted fs-5">Started with a vision to make AI automation accessible to businesses of all sizes.</p>
                            </div>
                        </div>
                        <div class="d-flex mb-5">
                            <div class="timeline-badge me-4">2021</div>
                            <div>
                                <h3 class="h4 fw-bold" style="color: #0A192F;">First enterprise client</h3>
                                <p class="text-muted fs-5">Deployed our first large-scale AI agent system, saving 2,400 hours monthly.</p>
                            </div>
                        </div>
                        <div class="d-flex mb-5">
                            <div class="timeline-badge me-4">2023</div>
                            <div>
                                <h3 class="h4 fw-bold" style="color: #0A192F;">Odoo expertise</h3>
                                <p class="text-muted fs-5">Became certified Odoo partners, expanding our enterprise solutions portfolio.</p>
                            </div>
                        </div>
                        <div class="d-flex">
                            <div class="timeline-badge me-4">2026</div>
                            <div>
                                <h3 class="h4 fw-bold" style="color: #0A192F;">Industry leader</h3>
                                <p class="text-muted fs-5">Now serving 50+ clients across manufacturing, retail, and professional services.</p>
                            </div>
                        </div>
                    </div>
                </section>

            </div>
        </xpath>
    </template>
</odoo>
