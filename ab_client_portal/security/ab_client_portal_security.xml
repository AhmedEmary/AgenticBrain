<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <record id="rule_project_task_portal_isolation" model="ir.rule">
            <field name="name">Client Portal: portal users only see tasks in their commercial org</field>
            <field name="model_id" ref="project.model_project_task"/>
            <field name="domain_force">[
                ('project_id.privacy_visibility', '=', 'portal'),
                '|',
                    ('partner_id.commercial_partner_id', '=', user.partner_id.commercial_partner_id.id),
                    ('message_partner_ids', 'child_of', [user.partner_id.commercial_partner_id.id]),
            ]</field>
            <field name="groups" eval="[(4, ref('base.group_portal'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="False"/>
            <field name="perm_create" eval="False"/>
            <field name="perm_unlink" eval="False"/>
        </record>

    </data>
</odoo>
