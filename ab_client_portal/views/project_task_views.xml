<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_task_form2_ab_client_portal" model="ir.ui.view">
        <field name="name">project.task.form.ab.client.portal</field>
        <field name="model">project.task</field>
        <field name="inherit_id" ref="project.view_task_form2"/>
        <field name="arch" type="xml">
            <xpath expr="//header" position="inside">
                <button name="action_internal_approve"
                        string="Approve"
                        type="object"
                        class="btn-primary"
                        groups="project.group_project_user"
                        invisible="client_status not in ('submitted', 'under_review') or approved_by"/>
                <field name="client_status" widget="statusbar" readonly="1"
                       options="{'clickable': '0'}"/>
            </xpath>

            <xpath expr="//notebook" position="inside">
                <page string="Client Portal" name="client_portal">
                    <group>
                        <group>
                            <field name="request_type"/>
                            <field name="affected_module"/>
                            <field name="client_priority"/>
                            <field name="estimate_hours"/>
                        </group>
                        <group>
                            <field name="is_client_editable" readonly="1"/>
                            <field name="approved_by" readonly="1"/>
                            <field name="approved_date" readonly="1"/>
                        </group>
                    </group>
                    <separator string="Acceptance Criteria"/>
                    <field name="acceptance_criteria"/>
                    <separator string="AI Triage Note" invisible="not ai_triage_note"/>
                    <field name="ai_triage_note" invisible="not ai_triage_note" readonly="1"/>
                </page>
            </xpath>
        </field>
    </record>

    <record id="view_task_list_ab_client_portal" model="ir.ui.view">
        <field name="name">project.task.list.ab.client.portal</field>
        <field name="model">project.task</field>
        <field name="inherit_id" ref="project.view_task_tree2"/>
        <field name="arch" type="xml">
            <field name="stage_id" position="after">
                <field name="client_status" optional="show"/>
                <field name="request_type" optional="hide"/>
                <field name="client_priority" optional="hide"/>
            </field>
        </field>
    </record>

    <record id="action_client_requests_pending" model="ir.actions.act_window">
        <field name="name">Pending Client Requests</field>
        <field name="res_model">project.task</field>
        <field name="view_mode">list,kanban,form</field>
        <field name="domain">[('client_status', 'in', ('submitted', 'under_review')), ('approved_by', '=', False)]</field>
        <field name="context">{'search_default_group_by_project': 1}</field>
    </record>

    <menuitem id="menu_client_requests_pending"
              name="Client Requests"
              parent="project.menu_main_pm"
              action="action_client_requests_pending"
              sequence="25"/>

</odoo>
