<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <record id="mail_template_request_acknowledgement" model="mail.template">
            <field name="name">Client Portal: Request Acknowledgement</field>
            <field name="model_id" ref="project.model_project_task"/>
            <field name="subject">We received your request: {{ object.name }}</field>
            <field name="email_from">{{ (object.project_id.user_id.email_formatted or user.email_formatted) }}</field>
            <field name="partner_to">{{ object.partner_id.id if object.partner_id else '' }}</field>
            <field name="use_default_to" eval="False"/>
            <field name="description">Sent automatically when a client submits a request from the portal.</field>
            <field name="body_html" type="html">
<div>
    <p>Hi <t t-out="object.partner_id.name or 'there'"/>,</p>
    <p>Thanks for submitting <strong t-out="object.name or ''"/>. We have it in our queue and our team will review it shortly.</p>
    <p>You can track the status of this request anytime from your portal: <a t-att-href="object.access_url" t-out="object.access_url or ''"/></p>
    <p>Talk soon,<br/>
       <t t-out="object.project_id.company_id.name or user.env.company.name or ''"/></p>
</div>
            </field>
            <field name="auto_delete" eval="True"/>
        </record>

        <record id="mail_template_status_change" model="mail.template">
            <field name="name">Client Portal: Status Update</field>
            <field name="model_id" ref="project.model_project_task"/>
            <field name="subject">Update on your request: {{ object.name }}</field>
            <field name="email_from">{{ (object.project_id.user_id.email_formatted or user.email_formatted) }}</field>
            <field name="partner_to">{{ object.partner_id.id if object.partner_id else '' }}</field>
            <field name="use_default_to" eval="False"/>
            <field name="description">Optional template for manual status updates to the client.</field>
            <field name="body_html" type="html">
<div>
    <p>Hi <t t-out="object.partner_id.name or 'there'"/>,</p>
    <p>Your request <strong t-out="object.name or ''"/> is now <strong t-out="dict(object._fields['client_status'].selection).get(object.client_status, object.client_status) or ''"/>.</p>
    <p>You can review the latest details in your portal: <a t-att-href="object.access_url" t-out="object.access_url or ''"/></p>
</div>
            </field>
            <field name="auto_delete" eval="True"/>
        </record>

    </data>
</odoo>
