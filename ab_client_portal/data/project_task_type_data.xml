<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <record id="stage_draft" model="project.task.type">
            <field name="name">Draft</field>
            <field name="sequence">1</field>
            <field name="fold" eval="False"/>
            <field name="user_id" eval="False"/>
        </record>

        <record id="stage_submitted" model="project.task.type">
            <field name="name">Submitted</field>
            <field name="sequence">2</field>
            <field name="fold" eval="False"/>
            <field name="user_id" eval="False"/>
        </record>

        <record id="stage_under_review" model="project.task.type">
            <field name="name">Under Review</field>
            <field name="sequence">3</field>
            <field name="fold" eval="False"/>
            <field name="user_id" eval="False"/>
        </record>

        <record id="stage_approved" model="project.task.type">
            <field name="name">Approved</field>
            <field name="sequence">4</field>
            <field name="fold" eval="False"/>
            <field name="user_id" eval="False"/>
        </record>

        <record id="stage_in_progress" model="project.task.type">
            <field name="name">In Progress</field>
            <field name="sequence">5</field>
            <field name="fold" eval="False"/>
            <field name="user_id" eval="False"/>
        </record>

        <record id="stage_delivered" model="project.task.type">
            <field name="name">Delivered</field>
            <field name="sequence">6</field>
            <field name="fold" eval="True"/>
            <field name="user_id" eval="False"/>
        </record>

    </data>
</odoo>
